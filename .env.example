# Copy this file to .env and adjust values for your local environment.
# The .env file is git-ignored - never commit real credentials.

# --- PostgreSQL ---
POSTGRES_USER=shop
POSTGRES_PASSWORD=changeme
POSTGRES_DB=shop
# Host-side port for the postgres service (container side is always 5432).
POSTGRES_PORT=5433

# --- Backend ---
# Host-side port for the backend service (container side is always 3000).
BACKEND_PORT=8080

# --- Frontend ---
# Host-side port for the frontend service (container side is always 3000).
FRONTEND_PORT=3000

# --- Backend connection string ---
DATABASE_URL=postgres://shop:changeme@localhost:5433/shop

JWT_SECRET=super-secret-key-change-in-production